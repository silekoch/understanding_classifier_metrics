{
  "name": "understanding_classifier_metrics",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Interactive playground for understanding classifier metrics.",
  "engines": {
    "node": "22.x",
    "npm": ">=10 <11"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --base=./",
    "preview": "vite preview",
    "verify:core": "npm run format:check && npm run lint:strict && npm test && npm run build",
    "verify": "npm run verify:core && npm run test:e2e",
    "check": "npm run verify:core",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:install:ci": "playwright install --with-deps chromium",
    "test:e2e": "playwright test -c e2e/playwright.config.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --cache",
    "lint:strict": "eslint . --cache --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "hooks:install": "bash scripts/setup-hooks.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.55.0",
    "eslint": "^9.22.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-playwright": "^2.9.0",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}
