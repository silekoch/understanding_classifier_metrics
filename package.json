{
  "name": "understanding_classifier_metrics",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Interactive playground for understanding classifier metrics.",
  "scripts": {
    "dev": "vite",
    "build": "vite build --base=./",
    "preview": "vite preview",
    "check": "npm run format:check && npm run lint:strict && npm test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --cache",
    "lint:strict": "eslint . --cache --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "hooks:install": "bash scripts/setup-hooks.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "vitest": "^2.1.8",
    "vite": "^6.2.0"
  }
}
